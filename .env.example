# Copy to .env and fill in. The .env file is gitignored.
# Gmail App Password (NOT your normal password). Create one at:
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-16-char-app-password

# Secret used to sign web session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If unset, the web app uses a random key each start (sessions won't persist).
TEEFINDER_SECRET_KEY=
